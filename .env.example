POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=internship_tracker

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/internship_tracker
DOCKER_DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/internship_tracker
SECRET_KEY=replace-this-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
APP_DEBUG=true
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
BACKEND_PORT=8001

STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=10
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.doc,.docx,.txt,.png,.jpg,.jpeg

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
S3_BUCKET=
S3_ENDPOINT_URL=
# Leave blank for private S3 documents. The app generates presigned URLs instead.
S3_PUBLIC_BASE_URL=

VITE_API_BASE_URL=http://localhost:8001
