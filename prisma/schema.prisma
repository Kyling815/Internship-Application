generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ai_analysis_results {
  id                      Int                     @id @default(autoincrement())
  application_id          Int
  cv_text                 String
  job_description         String
  match_score             Int
  matched_skills          Json                    @db.Json
  missing_skills          Json                    @db.Json
  suggested_improvements  Json                    @db.Json
  cover_letter            String
  created_at              DateTime                @default(now()) @db.Timestamptz(6)
  internship_applications internship_applications @relation(fields: [application_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([application_id], map: "ix_ai_analysis_results_application_id")
  @@index([id], map: "ix_ai_analysis_results_id")
}

model alembic_version {
  version_num String @id(map: "alembic_version_pkc") @db.VarChar(32)
}

model application_status_history {
  id                 Int              @id @default(autoincrement())
  job_application_id Int
  old_status         String?          @db.VarChar(50)
  new_status         String           @db.VarChar(50)
  changed_by_user_id Int?
  note               String?
  created_at         DateTime         @default(now()) @db.Timestamptz(6)
  users              users?           @relation(fields: [changed_by_user_id], references: [id], onUpdate: NoAction)
  job_applications   job_applications @relation(fields: [job_application_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([changed_by_user_id], map: "ix_application_status_history_changed_by_user_id")
  @@index([id], map: "ix_application_status_history_id")
  @@index([job_application_id], map: "ix_application_status_history_job_application_id")
}

model candidate_profiles {
  id              Int      @id @default(autoincrement())
  user_id         Int      @unique(map: "ix_candidate_profiles_user_id")
  full_name       String?  @db.VarChar(255)
  university      String?  @db.VarChar(255)
  major           String?  @db.VarChar(255)
  graduation_year Int?
  phone           String?  @db.VarChar(50)
  location        String?  @db.VarChar(255)
  linkedin_url    String?  @db.VarChar(500)
  github_url      String?  @db.VarChar(500)
  portfolio_url   String?  @db.VarChar(500)
  bio             String?
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)
  users           users    @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([id], map: "ix_candidate_profiles_id")
}

model companies {
  id            Int            @id @default(autoincrement())
  owner_user_id Int            @unique(map: "ix_companies_owner_user_id")
  name          String         @db.VarChar(255)
  description   String?
  website       String?        @db.VarChar(500)
  industry      String?        @db.VarChar(255)
  location      String?        @db.VarChar(255)
  logo_url      String?        @db.VarChar(500)
  created_at    DateTime       @default(now()) @db.Timestamptz(6)
  updated_at    DateTime       @default(now()) @db.Timestamptz(6)
  users         users          @relation(fields: [owner_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  job_postings  job_postings[]

  @@index([id], map: "ix_companies_id")
}

model documents {
  id                        Int                         @id @default(autoincrement())
  user_id                   Int
  application_id            Int
  document_type             String                      @db.VarChar(50)
  file_name                 String                      @db.VarChar(255)
  file_url                  String
  s3_key                    String
  created_at                DateTime                    @default(now()) @db.Timestamptz(6)
  internship_applications   internship_applications     @relation(fields: [application_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users                     users                       @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  job_application_documents job_application_documents[]

  @@index([application_id], map: "ix_documents_application_id")
  @@index([id], map: "ix_documents_id")
  @@index([user_id], map: "ix_documents_user_id")
}

model internship_applications {
  id                  Int                   @id @default(autoincrement())
  user_id             Int
  company_name        String                @db.VarChar(255)
  position_title      String                @db.VarChar(255)
  job_description     String
  application_status  String                @db.VarChar(50)
  deadline            DateTime?             @db.Date
  notes               String?
  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @default(now()) @db.Timestamptz(6)
  ai_analysis_results ai_analysis_results[]
  documents           documents[]
  users               users                 @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  interview_questions interview_questions[]

  @@index([id], map: "ix_internship_applications_id")
  @@index([user_id], map: "ix_internship_applications_user_id")
}

model interview_questions {
  id                      Int                     @id @default(autoincrement())
  application_id          Int
  question                String
  answer_hint             String
  created_at              DateTime                @default(now()) @db.Timestamptz(6)
  internship_applications internship_applications @relation(fields: [application_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([application_id], map: "ix_interview_questions_application_id")
  @@index([id], map: "ix_interview_questions_id")
}

model job_application_documents {
  id                 Int              @id @default(autoincrement())
  job_application_id Int
  document_id        Int
  document_type      String           @db.VarChar(50)
  created_at         DateTime         @default(now()) @db.Timestamptz(6)
  documents          documents        @relation(fields: [document_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  job_applications   job_applications @relation(fields: [job_application_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([job_application_id, document_id], map: "uq_job_application_documents_attachment")
  @@index([document_id], map: "ix_job_application_documents_document_id")
  @@index([id], map: "ix_job_application_documents_id")
  @@index([job_application_id], map: "ix_job_application_documents_job_application_id")
}

model job_applications {
  id                         Int                          @id @default(autoincrement())
  job_posting_id             Int
  candidate_user_id          Int
  status                     String                       @db.VarChar(50)
  cover_letter_text          String?
  candidate_note             String?
  submitted_at               DateTime                     @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime                     @default(now()) @db.Timestamptz(6)
  application_status_history application_status_history[]
  job_application_documents  job_application_documents[]
  users                      users                        @relation(fields: [candidate_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  job_postings               job_postings                 @relation(fields: [job_posting_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([job_posting_id, candidate_user_id], map: "uq_job_applications_job_candidate")
  @@index([candidate_user_id], map: "ix_job_applications_candidate_user_id")
  @@index([id], map: "ix_job_applications_id")
  @@index([job_posting_id], map: "ix_job_applications_job_posting_id")
}

model job_postings {
  id                 Int                @id @default(autoincrement())
  company_id         Int
  created_by_user_id Int
  title              String             @db.VarChar(255)
  description        String
  requirements       String?
  responsibilities   String?
  location           String?            @db.VarChar(255)
  employment_type    String             @db.VarChar(50)
  work_mode          String             @db.VarChar(50)
  salary_min         Int?
  salary_max         Int?
  deadline           DateTime?          @db.Date
  status             String             @db.VarChar(50)
  created_at         DateTime           @default(now()) @db.Timestamptz(6)
  updated_at         DateTime           @default(now()) @db.Timestamptz(6)
  job_applications   job_applications[]
  companies          companies          @relation(fields: [company_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users              users              @relation(fields: [created_by_user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([company_id], map: "ix_job_postings_company_id")
  @@index([created_by_user_id], map: "ix_job_postings_created_by_user_id")
  @@index([id], map: "ix_job_postings_id")
}

model users {
  id                         Int                          @id @default(autoincrement())
  email                      String                       @unique(map: "ix_users_email") @db.VarChar(255)
  full_name                  String?                      @db.VarChar(255)
  hashed_password            String                       @db.VarChar(255)
  is_active                  Boolean
  created_at                 DateTime                     @default(now()) @db.Timestamptz(6)
  role                       String                       @default("candidate") @db.VarChar(20)
  application_status_history application_status_history[]
  candidate_profiles         candidate_profiles?
  companies                  companies?
  documents                  documents[]
  internship_applications    internship_applications[]
  job_applications           job_applications[]
  job_postings               job_postings[]

  @@index([id], map: "ix_users_id")
}
